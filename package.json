{
  "name": "stockflow",
  "version": "0.1.0",
  "description": "Desktop stock management app built with Electron, React, TypeScript, and SQLite.",
  "main": "out/main/main.cjs",
  "author": "StockFlow",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/run-electron-vite.cjs dev",
    "build:app": "node scripts/run-electron-vite.cjs build",
    "build:win": "npm run build:app && electron-builder --win --x64 --config electron-builder.yml",
    "build": "npm run build:win",
    "preview": "node scripts/run-electron-vite.cjs preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vitejs/plugin-react": "5.1.1",
    "bcryptjs": "^3.0.3",
    "clsx": "latest",
    "electron-store": "^11.0.2",
    "electron-vite": "latest",
    "html5-qrcode": "^2.3.8",
    "lucide-react": "^1.18.0",
    "qrcode": "^1.5.4",
    "react": "latest",
    "react-dom": "latest",
    "react-router-dom": "^6.30.1",
    "recharts": "^3.8.1",
    "tailwindcss": "latest",
    "vite": "7.3.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "latest",
    "@types/qrcode": "^1.5.6",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "electron": "^35.7.5",
    "electron-builder": "latest",
    "typescript": "latest"
  }
}
